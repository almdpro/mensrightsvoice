# GEMINI_API_KEY: Required for Gemini AI API calls on server side.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL of the application.
APP_URL="MY_APP_URL"

# Formspree configuration (Alternative 1)
# Create a form at Formspree.io and paste the Form ID (the random string of characters) here:
FORMSPREE_FORM_ID=""

# EmailJS configuration (Alternative 2)
# Register a template on EmailJS and provide your service, template and keys here:
EMAILJS_SERVICE_ID=""
EMAILJS_TEMPLATE_ID=""
EMAILJS_PUBLIC_KEY=""
EMAILJS_PRIVATE_KEY=""
